# Python bytecode
__pycache__/
*.py[cod]

# Build / packaging output
build/
dist/

# Virtual environment
.venv/

# Test & coverage output
.pytest_cache/
.coverage
.coverage.*

# Linter and formatter
.ruff_cache/

# Microsoft Office lock files (PowerPoint creates these while a project
# .pptx output in src/saved_slides/ is open for editing — keep decks clean)
~$*.pptx

# App-specific runtime output (generated by the Flask app at request time)
src/saved_slides/

# Log files
*.log

# Editors
# VSCode
.vscode/

# Kiro runtime state
.kiro/state/
.kiro/cache/
.kiro/logs/
