# Python bytecode
__pycache__/
*.py[cod]

# Build / packaging output
build/
dist/

# Virtual environment
.venv/

# Test & coverage output
.hypothesis/
.pytest_cache/
.coverage
.coverage.*

# Linter and formatter
.ruff_cache/

# Microsoft Office lock files (PowerPoint creates these while a project
# .pptx output in data/saved_slides/ is open for editing — keep decks clean)
~$*.pptx

# Top-level runtime data directory — excludes everything under data/
# (currently data/saved_slides/, may grow in the future)
data/

# App-specific runtime output (generated by the Flask app at request time)
data/saved_slides/

# Log files
*.log

# VSCode
.vscode/

# Codex
.codex/

# Kiro runtime state
.kiro/state/
.kiro/cache/
.kiro/logs/

# Codegraph runtime state (local PID/socket, regenerated on every daemon start)
.codegraph/daemon.pid
