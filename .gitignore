# =============================================================================
# Python bytecode (generated by the interpreter when running tests / src/)
# =============================================================================
__pycache__/
*.py[cod]

# =============================================================================
# Build / packaging output (generated by `pip install .` / `python -m build`)
# =============================================================================
build/
dist/

# =============================================================================
# Virtual environment (uv creates `.venv` by default; `uv.lock` is committed)
# =============================================================================
.venv/

# =============================================================================
# Test & coverage output (generated by pytest + pytest-cov, dev deps)
# =============================================================================
.pytest_cache/
.coverage
.coverage.*

# =============================================================================
# Microsoft Office lock files (PowerPoint creates these while a project
# .pptx output in src/saved_slides/ is open for editing — keep decks clean)
# =============================================================================
~$*.pptx

# =============================================================================
# App-specific runtime output (generated by the Flask app at request time)
# =============================================================================
src/saved_slides/

# =============================================================================
# Kiro runtime state (keep steering files and specs in version control)
# =============================================================================
.kiro/state/
.kiro/cache/
.kiro/logs/
