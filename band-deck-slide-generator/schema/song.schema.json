{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/band-deck-slide-generator/song.schema.json",
  "title": "Band Deck Song [DEPRECATED]",
  "description": "[DEPRECATED] Legacy schema. Use song-deck.schema.yaml instead.",
  "type": "object",
  "required": ["song", "arrangement", "sections"],
  "additionalProperties": true,
  "properties": {
    "song": {
      "type": "object",
      "required": ["title", "authors", "target_key"],
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "authors": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "license_number": { "type": ["string", "integer", "null"] },
        "copyright": { "type": ["string", "null"] },
        "original_key": { "$ref": "#/$defs/keyOrUnknown" },
        "target_key": { "$ref": "#/$defs/keyOrUnknown" },
        "bpm": {
          "anyOf": [
            { "type": "integer", "minimum": 20, "maximum": 260 },
            { "type": "number", "minimum": 20, "maximum": 260 },
            { "type": "null" },
            { "type": "string" }
          ]
        },
        "time_signature": {
          "type": ["string", "null"],
          "pattern": "^(unknown|[0-9]+/[0-9]+)?$"
        },
        "capo": { "type": ["string", "integer", "null"] },
        "leader": { "type": ["string", "null"] },
        "notes": { "type": ["string", "array", "null"], "items": { "type": "string" } }
      }
    },
    "arrangement": {
      "type": "object",
      "required": ["sequence"],
      "additionalProperties": true,
      "properties": {
        "sequence": {
          "type": "array",
          "items": {
            "anyOf": [
              { "type": "string", "minLength": 1 },
              {
                "type": "object",
                "required": ["section"],
                "additionalProperties": true,
                "properties": {
                  "section": { "type": "string", "minLength": 1 },
                  "repeat": { "type": "integer", "minimum": 1 },
                  "label": { "type": "string" },
                  "cue": { "type": "string" }
                }
              }
            ]
          },
          "minItems": 1
        }
      }
    },
    "sections": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["lines"],
        "additionalProperties": true,
        "properties": {
          "label": { "type": "string" },
          "notes": { "type": ["string", "array", "null"], "items": { "type": "string" } },
          "lines": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["raw"],
              "additionalProperties": true,
              "properties": {
                "raw": { "type": "string" },
                "text": { "type": "string" },
                "chords": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["chord", "position"],
                    "additionalProperties": true,
                    "properties": {
                      "chord": { "$ref": "#/$defs/chord" },
                      "position": { "type": "integer", "minimum": 0 }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "cues": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "intro": { "$ref": "#/$defs/stringList" },
        "section_cues": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/stringList" }
        },
        "harmony": { "$ref": "#/$defs/stringList" },
        "instruments": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/stringList" }
        },
        "dynamics": { "$ref": "#/$defs/stringList" },
        "ending": { "$ref": "#/$defs/stringList" }
      }
    },
    "slides": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "aspect_ratio": { "type": "string", "default": "16:9" },
        "output_format": {
          "type": "string",
          "enum": ["marp", "markdown", "pdf", "html", "other"]
        },
        "audience": {
          "type": "string",
          "enum": ["band-practice", "congregation", "leader", "other"]
        },
        "density": {
          "type": "string",
          "enum": ["compact", "standard", "spacious"]
        },
        "include_overview": { "type": "boolean" },
        "include_final_review": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "keyOrUnknown": {
      "type": ["string", "null"],
      "pattern": "^(unknown|none|[A-G](b|#)?m?)?$"
    },
    "chord": {
      "type": "string",
      "pattern": "^[A-G](b|#)?(m|maj|min|dim|aug|sus|add)?[0-9]*(sus[24])?(add[0-9]+)?(maj[0-9]+)?(/[A-G](b|#)?)?$"
    },
    "stringList": {
      "anyOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } },
        { "type": "null" }
      ]
    }
  }
}
